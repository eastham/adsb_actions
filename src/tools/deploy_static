#!/usr/bin/env python3
"""
deploy_static - push static html/ files and examples/generated/index.html to remote storage.

Copies everything in html/ except excluded files, plus index.html from
examples/generated/.

Example:
    python src/tools/deploy_static
    python src/tools/deploy_static --dry-run
"""

import glob
import os
import subprocess
import argparse

DEFAULT_REMOTE = "hotspots-initial:hotspots"
HTML_DIR = "html"
GENERATED_DIR = "examples/generated"

# Files in HTML_DIR to skip (templates not meant for direct deployment)
HTML_EXCLUDE = ["index_template.html"]

# Extra individual files to deploy (relative to project root)
EXTRA_FILES = ["examples/generated/index.html"]

def main():
    parser = argparse.ArgumentParser(
        description="Deploy static site files to remote storage via rclone.")
    parser.add_argument("--remote", default=DEFAULT_REMOTE,
                        help=f"rclone remote destination (default: {DEFAULT_REMOTE})")
    parser.add_argument("--dry-run", "-n", action="store_true",
                        help="Print rclone commands without running them")
    args = parser.parse_args()

    files = []

    # Everything in html/ except excluded templates
    for path in sorted(glob.glob(os.path.join(HTML_DIR, "*"))):
        if os.path.isfile(path) and os.path.basename(path) not in HTML_EXCLUDE:
            files.append(path)

    # Extra individual files
    for path in EXTRA_FILES:
        if os.path.isfile(path):
            files.append(path)
        else:
            print(f"WARNING: {path} not found, skipping")

    print(f"Deploying {len(files)} files to {args.remote}")
    for f in files:
        cmd = ["rclone", "copyto", f, f"{args.remote}/{os.path.basename(f)}",
               "--progress",
               "--metadata-set", "cache-control=no-cache, must-revalidate"]
        if args.dry_run:
            cmd.append("--dry-run")
        print(f"  {' '.join(cmd)}")
        result = subprocess.run(cmd)
        if result.returncode != 0:
            print(f"  ERROR: rclone failed for {f} (exit {result.returncode})")

if __name__ == "__main__":
    main()
