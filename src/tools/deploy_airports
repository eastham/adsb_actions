#!/usr/bin/env python3
"""
deploy_airports - push generated files for a list of airports to remote storage.

Reads an airport list file (one code per line, # comments ignored) and runs
rclone copy for each airport's subdirectory under examples/generated/.

Example:
    python src/tools/deploy_airports examples/2nd_round_airports.txt
    python src/tools/deploy_airports examples/2nd_round_airports.txt --include "*.html"
    python src/tools/deploy_airports examples/2nd_round_airports.txt --dry-run

If a per-airport ICAO_deploy_filter.txt exists (generated by the aggregation step),
it takes precedence over --include, uploading only the map and sampled animation files.
"""

import os
import sys
import argparse
import subprocess
from batch_helpers import faa_to_icao

DEFAULT_REMOTE = "hotspots-initial:hotspots"
DEFAULT_GENERATED = "examples/generated"

def load_airports(path):
    airports = []
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            airports.append(line)
    return airports

def main():
    parser = argparse.ArgumentParser(
        description="Deploy generated airport files to remote storage via rclone.")
    parser.add_argument("airports_file",
                        help="Airport list file (one code per line, # comments ignored)")
    parser.add_argument("--remote", default=DEFAULT_REMOTE,
                        help=f"rclone remote destination (default: {DEFAULT_REMOTE})")
    parser.add_argument("--generated-dir", default=DEFAULT_GENERATED,
                        help=f"Local generated directory (default: {DEFAULT_GENERATED})")
    parser.add_argument("--include", default="*.html",
                        help="rclone --include glob pattern (default: *.html); "
                             "ignored if a per-airport deploy filter file exists")
    parser.add_argument("--dry-run", "-n", action="store_true",
                        help="Print rclone commands without running them")
    args = parser.parse_args()

    airports = load_airports(args.airports_file)
    if not airports:
        print(f"No airports found in {args.airports_file}", file=sys.stderr)
        sys.exit(1)

    print(f"Deploying {len(airports)} airports to {args.remote}", file=sys.stderr)

    failed = []
    for faa in airports:
        icao = faa_to_icao(faa)
        src = os.path.join(args.generated_dir, icao)
        dst = f"{args.remote}/{icao}"

        if not os.path.isdir(src):
            print(f"  SKIP {faa} ({icao}): no directory at {src}", file=sys.stderr)
            continue

        filter_file = os.path.join(src, f"{icao}_deploy_filter.txt")

        # Skip airports with no meaningful data: deploy filter exists but has no animations,
        # no LOS events, and no quality data (i.e. zero traffic — airport is out of coverage).
        # Airports with traffic data but no events still get a map with busyness/quality info.
        if os.path.exists(filter_file):
            with open(filter_file) as ff:
                filter_lines = [l.strip() for l in ff if l.strip().startswith("+")]
            has_animations = any(l != f"+ {icao}_map.html" for l in filter_lines)
            if not has_animations:
                combined_csv = os.path.join(src, f"{icao}_combined.csv.out")
                has_events = False
                if os.path.exists(combined_csv):
                    with open(combined_csv) as cf:
                        has_events = any("CSV OUTPUT" in line for line in cf)
                quality_json = os.path.join(src, f"{icao}_quality.json")
                has_traffic = os.path.exists(quality_json)
                if not has_events and not has_traffic:
                    print(f"  SKIP {icao}: no traffic data (out of coverage), nothing useful to deploy",
                          file=sys.stderr)
                    continue

        cmd = ["rclone", "copy", src, dst, "--progress",
               "--metadata-set", "cache-control=no-cache, must-revalidate"]
        if os.path.exists(filter_file):
            # Use filter file generated during aggregation (lists only kept animations + map)
            cmd += ["--filter-from", filter_file]
            print(f"  {icao}: using deploy filter {filter_file}", file=sys.stderr)
        else:
            cmd += ["--include", args.include]
            print(f"  {icao}: include pattern: {args.include}", file=sys.stderr)
        if args.dry_run:
            cmd.append("--dry-run")
        print(f"  {icao}: {' '.join(cmd)}", file=sys.stderr)

        result = subprocess.run(cmd)
        if result.returncode != 0:
            print(f"  ERROR: rclone failed for {icao} (exit {result.returncode})", file=sys.stderr)
            failed.append(icao)

    if failed:
        print(f"\nFailed airports: {', '.join(failed)}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
